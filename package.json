    "typescript": "^5.4.5",
    "vite": "^5.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.73",
    "@types/react-dom": "^18.2.23",
    "esbuild": "^0.21.5"
  },
  "engines": {
    "node": ">=20"
  }
