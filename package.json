    "@vitejs/plugin-react": "^6.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "resend": "^6.17.2",
    "typescript": "^5.4.5",
    "vite": "^8.0.14"
  },
  "devDependencies": {
    "@types/react": "^18.2.73",
    "@types/react-dom": "^18.2.23",
    "@vercel/node": "^5.8.17",
    "esbuild": "^0.28.0"
  },
  "engines": {
    "node": ">=20"
  }
}
