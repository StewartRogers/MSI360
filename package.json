{
  "name": "msi360-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test:automated": "node scripts/run-tests.mjs",
    "test:unit": "npm run test:automated",
    "test": "npm run typecheck && npm run test:automated"
  },
  "dependencies": {
